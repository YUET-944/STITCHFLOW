{
  "name": "stitchflow-backend",
  "version": "1.0.0",
  "description": "StitchFlow Backend built on Fastify",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build":        "tsc",
    "dev":          "tsx watch src/index.ts",
    "start":        "node dist/index.js",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio":    "prisma studio",
    "db:reset":     "prisma migrate reset --force",
    "db:seed":      "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/type-provider-typebox": "^4.0.0",
    "@prisma/client": "^5.12.0",
    "@sinclair/typebox": "^0.32.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.5",
    "dotenv-safe": "^9.0.0",
    "fastify": "^4.26.2",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^12.0.0",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dotenv-safe": "^8.1.5",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
