# ─────────────────────────────────────────────────────────────────
#  StitchFlow Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── Node Environment ──────────────────────────────────────────────
# Set to "production" on live servers. Changes error verbosity + security guards.
NODE_ENV="development"

# ── Server ───────────────────────────────────────────────────────
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────
# Connection string for local development with Docker
DATABASE_URL="postgresql://postgres:stitchflow_dev_pass@localhost:5433/stitchflow"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:stitchflow_dev_pass@localhost:5433/stitchflow"

# ── JWT Secrets ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# REQUIRED in production. If missing in prod, server will crash on startup.
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (in addition to localhost variants)
ALLOWED_ORIGINS="http://localhost:3000,capacitor://localhost"

# ── Logging ─────────────────────────────────────────────────────
# Fastify log levels: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# ── Demo / Development Bypass ─────────────────────────────────────
# DANGER: Set to "false" or remove entirely in production!
# When "true", allows login with username=KHAN password=KHAN (dev only).
# Code guards: only active when NODE_ENV != "production" AND this is "true".
ENABLE_DEMO_BYPASS="false"

# ── Firebase (OTP / Phone Auth) ──────────────────────────────────
# Set to "true" to skip real Firebase in local development.
# Set to "false" (and configure service account) in production.
MOCK_FIREBASE="true"

# ── Cloudinary (PDF / Image Storage) ────────────────────────────
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"
